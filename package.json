{
  "name": "eecs280-setup",
  "displayName": "EECS 280 Setup",
  "description": "One-click environment setup and verification for EECS 280 at the University of Michigan. Installs required extensions, applies course settings, and verifies your development environment.",
  "version": "1.0.0",
  "publisher": "kyukibug",
  "author": {
    "name": "Alex Ni"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kyukibug/eecs280-setup"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Education",
    "Other"
  ],
  "keywords": [
    "eecs280",
    "umich",
    "university of michigan",
    "c++",
    "setup"
  ],
  "icon": "images/icon.png",
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "eecs280.verifySetup",
        "title": "EECS 280: Verify Setup",
        "category": "EECS 280"
      }
    ],
    "configurationDefaults": {
      "chat.disableAIFeatures": true
    }
  },
  "extensionDependencies": [
    "ms-vscode.cpptools",
    "vadimcn.vscode-lldb",
    "ms-vscode-remote.remote-wsl"
  ],
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}